{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,js,json,xml,txt,map,png,jpg,jpeg,gif,ico,svg,webp,avif,woff,woff2,ttf,eot,otf,mp4,webm}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".webmanifest": "application/manifest+json"
  }
}
